import java.util.*;
public class Q17
{
    public static void main()
    {
        Scanner sc=new Scanner(System.in);
        int i,n,s=0;
        System.out.print("Enter the number to be checked = ");
        n=sc.nextInt();
        System.out.println();
        for(i=1;i<n;i++)
        {
            if(n%i==0)
            {
                s=s+i;
            }
            else 
            {
                continue;
            }
        }
        if(s==n)
        {
            System.out.print(n+" is a perfect number");
        }
        else
        {
            System.out.print(n+" is not an perfect number");
        }
    }

}

